@model IEnumerable<PieShop.Models.Pie>

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Pie Shop</title>
</head>
<body>
    <h2>@ViewBag.CurrentCategory</h2>

    @foreach (var pie in Model)
    {
        <div>
            <h2><a href="/Pie/Details/@pie.PieId">@pie.Name</a></h2>
            <h3>@pie.Price.ToString("c")</h3>
            <h4>@pie.ShortDescription</h4>
            <h2><a href="/Pie/Details/@pie.PieId">@pie.Name</a></h2>

        </div>
    }

</body>
</html>
