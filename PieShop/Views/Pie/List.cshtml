@* @model IEnumerable<BethanysPieShop.Models.Pie> *@

@model PieListViewModel

@* <h1 class="mt-5 pt-4">Pies</h1> *@
@* <h1 class="mt-5 pt-4">@ViewData["Title"]</h1> *@
<h1 class="mt-5 pt-4">@ViewBag.Title</h1>

<h2>@(Model.CurrentCategory)</h2>

<div class="row row-cols-1 row-cols-md-3 g-4">
	@foreach (var pie in Model.Pies)
	{
		<div class="col">
			<div class="card pie-card h-100 position-relative">
				@if (!string.IsNullOrWhiteSpace(pie.ImageThumbnailUrl))
				{
					<a href="/Pie/Details/@pie.PieId" title="@pie.Name">
						<img src="@pie.ImageThumbnailUrl"
							 class="card-img-top"
							 alt="@pie.Name"
							 loading="lazy"
							 decoding="async">
					</a>
				}
				else
				{
					<a href="/Pie/Details/@pie.PieId" title="@pie.Name"
					   class="d-flex align-items-center justify-content-center bg-light"
					   style="height:200px;">
						<span class="text-muted">No image</span>
					</a>
				}

				<div class="card-body pie-button d-flex flex-column">
					<div class="d-flex justify-content-between align-items-start mt-2">
						<h2 class="h5 text-start mb-0">
							<a href="/Pie/Details/@pie.PieId" class="pie-link stretched-link">@pie.Name</a>
						</h2>
						<h5 class="text-nowrap mb-0">
							@pie.Price.ToString("c")
						</h5>
					</div>

					@if (!string.IsNullOrWhiteSpace(pie.ShortDescription))
					{
						<p class="text-muted mt-2 mb-0">@pie.ShortDescription</p>
					}
				</div>
			</div>
		</div>
	}
</div>
