@model Order

<form asp-action="Checkout" method="post" role="form">
    <h3 class="my-5">You're just one step away from your delicious pies.</h3>

    <!-- Validation summary as Bootstrap alert -->
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="row g-3">
        <!-- First / Last name -->
        <div class="col-12 col-md-6">
            <label asp-for="FirstName" class="form-label"></label>
            <input asp-for="FirstName" class="form-control" autocomplete="given-name" />
            <span asp-validation-for="FirstName" class="invalid-feedback d-block"></span>
        </div>

        <div class="col-12 col-md-6">
            <label asp-for="LastName" class="form-label"></label>
            <input asp-for="LastName" class="form-control" autocomplete="family-name" />
            <span asp-validation-for="LastName" class="invalid-feedback d-block"></span>
        </div>

        <!-- Address -->
        <div class="col-12">
            <label asp-for="AddressLine1" class="form-label"></label>
            <input asp-for="AddressLine1" class="form-control" autocomplete="address-line1" />
            <span asp-validation-for="AddressLine1" class="invalid-feedback d-block"></span>
        </div>

        <div class="col-12">
            <label asp-for="AddressLine2" class="form-label"></label>
            <input asp-for="AddressLine2" class="form-control" autocomplete="address-line2" />
            <span asp-validation-for="AddressLine2" class="invalid-feedback d-block"></span>
        </div>

        <!-- City / State -->
        <div class="col-12 col-md-6">
            <label asp-for="City" class="form-label"></label>
            <input asp-for="City" class="form-control" autocomplete="address-level2" />
            <span asp-validation-for="City" class="invalid-feedback d-block"></span>
        </div>

        <div class="col-12 col-md-6">
            <label asp-for="State" class="form-label"></label>
            <input asp-for="State" class="form-control" autocomplete="address-level1" />
            <span asp-validation-for="State" class="invalid-feedback d-block"></span>
        </div>

        <!-- Zip / Country -->
        <div class="col-12 col-md-6">
            <label asp-for="ZipCode" class="form-label"></label>
            <input asp-for="ZipCode" class="form-control" inputmode="numeric" autocomplete="postal-code" />
            <span asp-validation-for="ZipCode" class="invalid-feedback d-block"></span>
        </div>

        <div class="col-12 col-md-6">
            <label asp-for="Country" class="form-label"></label>
            <input asp-for="Country" class="form-control" autocomplete="country-name" />
            <span asp-validation-for="Country" class="invalid-feedback d-block"></span>
        </div>

        <!-- Email / Phone -->
        <div class="col-12 col-md-6">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" type="email" autocomplete="email" />
            <span asp-validation-for="Email" class="invalid-feedback d-block"></span>
        </div>

        <div class="col-12 col-md-6">
            <label asp-for="PhoneNumber" class="form-label"></label>
            <input asp-for="PhoneNumber" class="form-control" type="tel" inputmode="tel" autocomplete="tel" />
            <span asp-validation-for="PhoneNumber" class="invalid-feedback d-block"></span>
        </div>

        <!-- Submit -->
        <div class="col-12 d-grid d-md-flex justify-content-md-end mt-2">
            <button type="submit" class="btn btn-primary btn-lg">Complete order</button>
        </div>
    </div>
</form>
